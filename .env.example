# TREK Configuration - Environment Variables

# ========================================
# Server Configuration
# ========================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
TZ=UTC

# ========================================
# First Run Admin Account
# ========================================
# These are only used on first boot when no users exist
ADMIN_EMAIL=admin@trek.local
ADMIN_PASSWORD=admin123

# ========================================
# Security & Encryption
# ========================================
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ========================================
# CORS & Networking
# ========================================
# ALLOWED_ORIGINS=
# TRUST_PROXY=1
# FORCE_HTTPS=true
# COOKIE_SECURE=false
# ALLOW_INTERNAL_NETWORK=false

# ========================================
# Public URL
# ========================================
# Required when OIDC is enabled
# APP_URL=https://trek.example.com

# ========================================
# Google Gemini Integration (Optional)
# ========================================
# GEMINI_API_KEY=your_google_ai_studio_key_here
# GEMINI_MODEL=gemini-3.1-pro-preview
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

# ========================================
# OpenID Connect (OIDC) Configuration (Optional)
# ========================================
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=trek
# OIDC_CLIENT_SECRET=supersecret
# OIDC_DISPLAY_NAME=SSO
# OIDC_ONLY=false
# OIDC_ADMIN_CLAIM=groups
# OIDC_ADMIN_VALUE=app-trek-admins
# OIDC_SCOPE=openid email profile
# OIDC_DISCOVERY_URL=

# ========================================
# MCP Server Configuration (Optional)
# ========================================
# MCP_RATE_LIMIT=60
# MCP_MAX_SESSION_PER_USER=5
